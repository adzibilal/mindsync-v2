# Database
DATABASE_URL=postgresql+asyncpg://mindsync:mindsync@postgres:5432/mindsync

# Qdrant
QDRANT_URL=http://qdrant:6333

# WAHA (self-hosted, e.g. https://waha.example.com)
WAHA_URL=https://waha.example.com
WAHA_API_KEY=change-me
WAHA_HMAC_KEY=change-me-hmac
# Public URL of this backend so WAHA can POST webhooks (tunnel URL in dev, e.g. https://xxx.trycloudflare.com)
WEBHOOK_URL=

# LiteLLM
LITELLM_BASE_URL=https://litellm.yourapp.com
LITELLM_API_KEY=sk-litellm-change-me

# JWT
JWT_SECRET=change-me-jwt-secret

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# LLM Retry
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
LLM_TIMEOUT=60

# RAG
DEFAULT_TOP_K=4
DEFAULT_THRESHOLD=0.5
DEFAULT_MAX_HISTORY_TURNS=6
DEBOUNCE_SECONDS=2.5
MAX_MESSAGE_LENGTH=4000

# Postgres credentials
POSTGRES_USER=mindsync
POSTGRES_PASSWORD=mindsync
POSTGRES_DB=mindsync
